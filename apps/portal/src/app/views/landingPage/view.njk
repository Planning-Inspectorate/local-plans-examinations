{% extends "views/layouts/main.njk" %}



{% block pageContent %}
  
  <p class="govuk-body">
    {{ message }}
  </p>

    {% from "govuk/components/table/macro.njk" import govukTable %}




  {{ govukTable({
    captionClasses: "govuk-table__caption--l",
    firstCellIsHeader: true,
    head: [
      {
        text: "Reference Number"
      },
      {
        text: "Lead Local Planning Authority"
      },
      {
        text: "Plan Title"
      },
      {
        text: "Current Stage"
      },
      {
        text: "Status"
      }
    ],
    rows: plans
    
  }) }}



{% endblock %}