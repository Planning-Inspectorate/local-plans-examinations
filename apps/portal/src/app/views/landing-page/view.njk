{% extends "views/layouts/main.njk" %}
{% from "govuk/components/table/macro.njk" import govukTable %}



{% block pageContent %}

  {% if noPlansFlag %}

    <h2 class="govuk-heading-m">No plans available</h2>

  {% else %}

    {{ govukTable({
      classes: "govuk-table--responsive",
      captionClasses: "govuk-table__caption--l",
      firstCellIsHeader: true,
      head: [
        {
          text: "Reference number"
        },
        {
          text: "Lead local planning authority"
        },
        {
          text: "Plan title"
        },
        {
          text: "Current stage"
        },
        {
          text: "Status"
        }
      ],
      rows: plans
    })}}

  {% endif %}

{% endblock %}
