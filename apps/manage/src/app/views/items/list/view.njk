{% extends "views/layouts/main.njk" %}

{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% block pageTitle %}
    Local Plans Examination Service - {{ config.headerTitle }}
{% endblock %}

{% block pageContent %}
    <a href="/create-a-case/case-details/name">Create a basic case</a>
    {% set tableRows = [] %}

    {% for item in items %}
        {% set tagText = 'TO DO' %}
        {% if item.done %}
            {% set tagText = 'DONE' %}
        {% endif %}
        {% set tableRows = (tableRows.push([
            {
                text: item.task
            },
            {
                html: govukTag({text: tagText})
            }
        ]), tableRows) %}
    {% endfor %}

    {{ govukTable({
        head: [
            {
                text: "Task"
            },
            {
                text: "Status"
            }
        ],
        rows: tableRows
    }) }}

{% endblock %}