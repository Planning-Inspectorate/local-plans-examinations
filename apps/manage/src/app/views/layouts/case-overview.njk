{% extends "views/layouts/main.njk" %}
{% from "govuk/components/service-navigation/macro.njk" import govukServiceNavigation %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}


{% block pageContent %}
<span class="govuk-caption-l">{{ currentCase.reference }}</span>
<h1 class="govuk-heading-l">{{ currentCase.planTitle }}</h1>
<h1 class="govuk-heading-l">{{ test }}</h1>


{{ govukServiceNavigation({
  navigation: [
    {
      href: "#",
      text: "Overview",
      active: true
    },
    {
      href: "#",
      text: "Timetable"
    },
    {
      href: "#",
      text: "Gateway 1"
    },
    {
      href:"#",
      text: "Gateway 2"
    },
    {
      href:"#",
      text: "Gateway 3"
    },
    {
      href:"#",
      text: "Examination"
    },
    {
      href:"#",
      text: "Case History"
    }
  ],
  attributes: {
    "id": "service-navigation",
    "data-cy": "service-navigation"
  }
}) }}
{{ govukSummaryList({
  rows: rows
}) }}

<div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
            {% for section in summaryListData.sections %}
                {% if section.list.rows.length %}
                    {{ govukSummaryList({

                        rows: section.list.rows
                    }) }}
                {% endif %}
            {% endfor %}
        </div>
    </div>
{% endblock %}

