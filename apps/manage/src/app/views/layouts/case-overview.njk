{% extends "views/layouts/main.njk" %}
{% from "govuk/components/service-navigation/macro.njk" import govukServiceNavigation %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}


{% block pageContent %}
  <span class="govuk-caption-l">{{ reference }}</span>
  <h1 class="govuk-heading-l">{{ planTitle }}</h1>

  {% for section in summaryListData.sections %}
    {% if loop.first and section.list.rows.length %}
      <h1 class="govuk-heading-l">{{ section.list.rows[0].value.text }}</h1>
    {% endif %}
  {% endfor %}
{{ govukServiceNavigation({
  attributes: { "id": "service-navigation", "data-cy": "service-navigation" },
  navigation: [
    {
      href: "#",
      text: "Overview",
      active: true
    },
    {
      href: "#",
      text: "Timetable"
    },
    {
      href: "#",
      text: "Gateway 1"
    },
    {
      href:"#",
      text: "Gateway 2"
    },
    {
      href:"#",
      text: "Gateway 3"
    },
    {
      href:"#",
      text: "Examination"
    },
    {
      href:"#",
      text: "Case History"
    }
  ],
  attributes: {
    "id": "service-navigation",
    "data-cy": "service-navigation"
  }
}) }}

<div class="govuk-grid-row govuk-!-margin-top-6">
        <div class="govuk-grid-column-full">
            {% for section in summaryListData.sections %}
                {% if section.list.rows.length %}
                  <h2 class="govuk-heading-l">{{ section.heading }}</h2>
                  {{ govukSummaryList({
                        rows: section.list.rows
                    }) }}
                {% endif %}
            {% endfor %}
        </div>
    </div>
{% endblock %}

