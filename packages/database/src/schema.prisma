generator client {
  provider = "prisma-client"
  output   = "./client"

  engineType = "client"
  runtime    = "nodejs"
}

datasource db {
  provider = "sqlserver"
}

// NOTES
//
// use '//' comments for notes relevant to the schema
// use '///' comments for notes that should be included in the types definition
// see https://www.prisma.io/docs/concepts/components/prisma-schema#comments
//
// we use GUIDs for IDs (see https://learn.microsoft.com/en-us/sql/t-sql/data-types/uniqueidentifier-transact-sql?view=sql-server-ver16)
// this is because these IDs may be used in URLs and it makes them harder to guess
// while we don't rely on that for security, it adds an extra layer
// not everything needs this, but easier to make them all consistent and the increase in size (vs int) is negligible

model Case {
  id                        String        @id @default(uuid()) @db.UniqueIdentifier
  reference                 String        @unique
  email                     String
  caseOfficer               String
  planTitle                 String
  planType                  String
  planBand                  String?
  lpas                      LPA[]
  contacts                  Contact[]
  programmeOfficerFirstName String?
  programmeOfficerLastName  String?
  programmeOfficerEmail     String?
  examinationWebsite        String?
  assessorGateway2          String?
  assessorGateway3          String?
  examiningInspector1       String?
  examiningInspector2       String?
  examiningInspector3       String?
  qaInspector1              String?
  qaInspector2              String?
  qaInspector3              String?
  intentionToCommenceDate   DateTime?
  gateway1Date              DateTime?
  gateway2Date              DateTime?
  gateway3Date              DateTime?
  submissionDate            DateTime?
  createdAt                 DateTime      @default(now())
  noticeOfIntention         DateTime?
  estimatedGateway1Date     DateTime?
  completedGateway1Date     DateTime?
  slaSentDate               DateTime?
  slaReceivedDate           DateTime?
  dsaChecked                String?
  gateways                  Gateway[]
  caseHistories             CaseHistory[]
}

model LPA {
  lpaCode  String    @id
  contacts Contact[]
  cases    Case[]
}

model Contact {
  id          String @id @default(uuid()) @db.UniqueIdentifier
  firstName   String @db.NVarChar(100)
  lastName    String @db.NVarChar(100)
  email       String @db.NVarChar(320)
  phoneNumber String @db.NVarChar(30)
  lpaCode     String
  cases       Case[]
  lpa         LPA    @relation(fields: [lpaCode], references: [lpaCode])
}

model OneTimePassword {
  email            String    @id
  hashedOtp        String
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  attempts         Int       @default(0)
  locked_out_until DateTime? @db.DateTime2
}

model NotifyEmail {
  id              String    @id @default(uuid()) @db.UniqueIdentifier
  notifyId        String    @db.NVarChar(100)
  reference       String?   @db.NVarChar(1000)
  createdDate     DateTime? @db.DateTime2
  completedDate   DateTime? @db.DateTime2
  status          String    @db.NVarChar(100)
  templateId      String?   @db.NVarChar(100)
  templateVersion Int?
  body            String?   @db.NVarChar(Max)
  subject         String?   @db.NVarChar(Max)
  email           String?   @db.NVarChar(100)
}

model Gateway {
  id           String @id @db.NVarChar(2)
  displayName  String @db.NVarChar(100)
  folderName   String @db.NVarChar(100)
  displayOrder Int

  categories  DocumentCategory[]
  documentSet DocumentSet[]
  cases       Case[]
}

model DocumentCategory {
  id String @id @db.NVarChar(4)

  gatewayId String  @db.NVarChar(2)
  gateway   Gateway @relation(fields: [gatewayId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  displayName  String @db.NVarChar(200) // Procedural, Consultation
  folderName   String @db.NVarChar(200)
  displayOrder Int?

  documentSets DocumentSet[]

  @@unique([gatewayId, displayName])
  @@index([gatewayId])
}

model DocumentSet {
  id String @id @db.NVarChar(20)

  gatewayId String  @db.NVarChar(2)
  gateway   Gateway @relation(fields: [gatewayId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  documentCategoryId String           @db.NVarChar(4)
  documentCategory   DocumentCategory @relation(fields: [documentCategoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  displayName  String @db.NVarChar(200) // Covering Letter, Initiation Document
  folderName   String @db.NVarChar(200)
  displayOrder Int?

  @@unique([documentCategoryId, displayName])
  @@index([documentCategoryId])
}

model CaseHistory {
  id       String   @id @default(uuid()) @db.UniqueIdentifier
  date     DateTime @default(now())
  event    String   @db.NVarChar(200)
  caseId   String   @db.UniqueIdentifier
  username String   @db.NVarChar(100)
  case     Case     @relation(fields: [caseId], references: [id])
}
