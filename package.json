{
  "name": "local-plans",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "check-types": "npx tsc",
    "commitlint": "commitlint --from=$(git rev-parse $(git cherry origin/main | head -n 1 | cut -c 3-)^1)",
    "db-migrate-dev": "npm run migrate-dev --workspace @pins/local-plans-database",
    "db-migrate-prod": "npm run migrate-prod --workspace @pins/local-plans-database",
    "db-generate": "npm run generate --workspace @pins/local-plans-database",
    "db-seed": "npm run seed --workspace @pins/local-plans-database",
    "db-seed-prod": "npm run seed:prod --workspace @pins/local-plans-database",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "lint": "npx eslint .",
    "prepare": "node .husky/install.mjs",
    "test": "node --test",
    "test-coverage": "node --test --experimental-test-coverage",
    "cy:portal:smoke": "cross-env TEST_TARGET=portal npx cypress run --env grepTags=smoke --spec='cypress/e2e/portal/**/*'",
    "cy:portal:regression": "cross-env TEST_TARGET=portal npx cypress run --env grepTags=regression --spec='cypress/e2e/portal/**/*'",
    "cy:portal:all": "cross-env TEST_TARGET=portal npx cypress run --spec='cypress/e2e/portal/**/*'",
    "cy:open:portal": "cross-env TEST_TARGET=portal npx cypress open",
    "cy:manage:smoke": "cross-env TEST_TARGET=manage npx cypress run --env grepTags=smoke --spec='cypress/e2e/manage/**/*'",
    "cy:manage:regression": "cross-env TEST_TARGET=manage npx cypress run --env grepTags=regression --spec='cypress/e2e/manage/**/*'",
    "cy:manage:all": "cross-env TEST_TARGET=manage npx cypress run --spec='cypress/e2e/manage/**/*'",
    "cy:open:manage": "cross-env TEST_TARGET=manage npx cypress open"
  },
  "dependencies": {
    "@azure/functions": "^4.11.2",
    "@azure/identity": "^4.13.0",
    "@azure/msal-node": "^5.1.0",
    "@planning-inspectorate/dynamic-forms": "^3.3.4",
    "@prisma/adapter-mssql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "accessible-autocomplete": "^3.0.1",
    "body-parser": "^2.2.1",
    "connect-redis": "^9.0.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "govuk-frontend": "^6.1.0",
    "helmet": "^8.1.0",
    "nunjucks": "^3.2.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.2",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@cypress/grep": "^6.0.0",
    "@cypress/webpack-preprocessor": "^7.1.0",
    "@eslint/js": "^10.0.1",
    "@microsoft/microsoft-graph-types": "^2.43.1",
    "@types/express": "^5.0.5",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.5.0",
    "@types/nunjucks": "^3.2.6",
    "cookie-parser": "^1.4.7",
    "cross-env": "^10.1.0",
    "cypress": "^15.12.0",
    "cypress-mochawesome-reporter": "^4.0.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "nodemon": "^3.1.11",
    "playwright-core": "^1.59.0",
    "prettier": "^3.8.1",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^7.7.0",
    "sass": "^1.97.3",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "webpack": "^5.106.2"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ],
    "*.{js,ts,json,md,prisma,yml,yaml,scss}": [
      "prettier --write"
    ]
  }
}
